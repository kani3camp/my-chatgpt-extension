{
  "manifest_version": 3,
  "name": "ChatGPT Response Notifier",
  "version": "0.1.0",
  "description": "Play a notification sound when ChatGPT finishes responding.",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT Response Notifier",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "offscreen.js"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ]
}
